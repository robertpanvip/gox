package main

import go "fmt"

public func testLet() {
    // 测试 let 声明
    let x: int = 10
    let y = 20
    let z: string = "hello"
    
    fmt.println(x)
    fmt.println(y)
    fmt.println(z)
}

public func testConst() {
    // 测试 const 声明
    const PI: float64 = 3.14159
    const Name: string = "Gox"
    
    fmt.println(PI)
    fmt.println(Name)
}

public func testTypes() {
    // 测试基础类型
    let a: int = 42
    let b: string = "test"
    let c: bool = true
    let d: float64 = 3.14
    
    fmt.println(a)
    fmt.println(b)
    fmt.println(c)
    fmt.println(d)
}

public func Main() {
    testLet()
    testConst()
    testTypes()
}
