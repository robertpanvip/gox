package main

import go "fmt"
import go "github.com/fogleman/gg"

public func Main() {
    // 创建 800x600 画布
    let dc = gg.NewContext(800, 600)
    
    // 设置背景色（浅灰色）
    dc.SetRGB(0.9, 0.9, 0.9)
    dc.Clear()
    
    // 绘制红色矩形
    dc.SetRGB(1, 0, 0)
    dc.DrawRectangle(100, 100, 200, 150)
    dc.Fill()
    
    // 绘制蓝色圆形
    dc.SetRGB(0, 0, 1)
    dc.DrawCircle(400, 300, 80)
    dc.SetLineWidth(5)
    dc.Stroke()
    
    // 绘制绿色椭圆
    dc.SetRGB(0, 1, 0)
    dc.DrawEllipse(600, 400, 100, 50)
    dc.Fill()
    
    // 绘制文字
    dc.SetRGB(0, 0, 0)
    dc.DrawString("Hello from Gox + gg!", 50, 50)
    
    // 保存为 PNG 文件
    dc.SavePNG("output.png")
    
    fmt.println("Image saved to output.png")
}
