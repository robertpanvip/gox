package main

// 测试 Go 包导入 - 显式声明
import go "fmt"
import go "strings"

// 测试 Gox 包导入 - 显式声明（或省略）
import gox "mygox/utils"
import "mygox/helper"  // 默认 gox

public func Main() {
    // Go 包 - 自动转换可见性（小写转大写）
    fmt.println("Hello")      // → fmt.Println
    strings.toupper("x")      // → strings.ToUpper
    fmt.println("World")      // → fmt.Println
    
    // Gox 包 - 保持原样
    utils.helper()            // → utils.helper
    helper.init()             // → helper.init
    
    // 混合使用
    fmt.println(strings.toupper("test"))  // → fmt.Println(strings.ToUpper("test"))
}
