package main

import go "fmt"

public func Main() {
    let x = 10
    let y = 20
    let sum = x + y
    
    fmt.println("x = 10")
    fmt.println("y = 20")
    fmt.println("sum = x + y = " + fmt.Sprintf("%d", sum))
    
    let arr = [1, 2, 3]
    let len = len(arr)
    fmt.println("Array length: " + fmt.Sprintf("%d", len))
    
    if sum > 25 {
        fmt.println("sum is greater than 25")
    } else {
        fmt.println("sum is less than or equal to 25")
    }
    
    let i = 5
    while i > 0 {
        fmt.print(fmt.Sprintf("%d ", i))
        i = i - 1
    }
    fmt.println("Done!")
}
