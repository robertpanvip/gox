package main

import go "fmt"
import go "github.com/hajimehoshi/ebiten/v2"
import go "github.com/fogleman/gg"

// 游戏结构体
public type Game struct {
    img: *ebiten.Image
    width: int
    height: int
}

// Update 每帧调用（逻辑更新）
public func (g: Game) Update(): error {
    return nil
}

// Draw 每帧调用（渲染）
public func (g: Game) Draw(screen: *ebiten.Image) {
    // 将 gg 生成的图像绘制到屏幕
    screen.DrawImage(g.img, nil)
}

// Layout 返回窗口尺寸
public func (g: Game) Layout(outsideWidth: int, outsideHeight: int): (int, int) {
    return g.width, g.height
}

public func Main() {
    fmt.println("=== Gox + gg + Ebiten Demo ===")
    
    // 1. 使用 gg 绘图
    let width = 800
    let height = 600
    let dc = gg.NewContext(width, height)
    
    // 绘制背景（白色）
    dc.SetRGB(1, 1, 1)
    dc.Clear()
    
    // 绘制红色圆形
    dc.SetRGB(1, 0, 0)
    dc.DrawCircle(400, 300, 100)
    dc.Fill()
    
    // 绘制绿色矩形
    dc.SetRGB(0, 1, 0)
    dc.DrawRectangle(200, 200, 150, 150)
    dc.Fill()
    
    // 绘制蓝色椭圆
    dc.SetRGB(0, 0, 1)
    dc.DrawEllipse(600, 400, 120, 60)
    dc.Fill()
    
    // 绘制文字
    dc.SetRGB(0, 0, 0)
    dc.DrawString("Hello from Gox!", 50, 50)
    dc.DrawString("gg + Ebiten = Perfect!", 50, 80)
    dc.DrawString("Press ESC to exit", 50, 110)
    
    // 2. 获取 gg 生成的图像并转换为 Ebiten Image
    let img = dc.Image()
    let ebitenImg = ebiten.NewImageFromImage(img)
    
    fmt.println("Image created and converted!")
    fmt.println("Window size: 800x600")
    fmt.println("Starting Ebiten game loop...")
    
    // 3. 设置 Ebiten
    ebiten.SetWindowSize(width, height)
    ebiten.SetWindowTitle("Gox + gg + Ebiten")
    
    // 4. 运行游戏循环
    let err = ebiten.RunGame(&Game{
        img: ebitenImg,
        width: width,
        height: height,
    })
    
    if err != nil {
        fmt.println("Error: " + err.Error())
    }
    
    fmt.println("Game exited.")
}
