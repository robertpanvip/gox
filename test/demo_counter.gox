import "github.com/gox-lang/gox/gui"

// FX 组件示例 - 计数器
fx func Counter() {
    let count = 0
    
    return <div>
        <h1 text={ "Count: " + count } />
        <button text="Increment" onClick={() => {
            count = count + 1
        }} />
        <button text="Decrement" onClick={() => {
            count = count - 1
        }} />
        <button text="Reset" onClick={() => {
            count = 0
        }} />
    </div>
}

func Main() {
    let counter = NewCounter()
    println("Counter app started")
}
