package main

// 数组字面量测试
let numbers = [1, 2, 3]
let empty: int[] = []
let names = ["Alice", "Bob", "Charlie"]
let matrix = [[1, 2], [3, 4]]

// 数组类型扩展方法
extend int[] {
    public func map(fn: func(int): int): int[] {
        return self
    }
    
    public func filter(fn: func(int): bool): int[] {
        return self
    }
}

// 使用数组方法
let doubled = numbers.map(func(x: int): int => x * 2)
let evens = numbers.filter(func(x: int): bool => x % 2 == 0)

// 函数和闭包
public func add(x: int, y: int): int {
    return x + y
}

let subtract = func(a: int, b: int): int => a - b
let multiply = func(x: int, y: int): int { return x * y }

// 泛型函数
public func identity[T](x: T): T {
    return x
}

// 高阶函数
public func apply(fn: func(int): int, x: int): int {
    return fn(x)
}

// 变量声明和类型推断
let a = 10
let b: int = 20
let c = add(a, b)
let result1 = subtract(30, 5)
let result2 = multiply(3, 4)
let result3 = apply(func(x: int): int => x * 2, 5)

// 箭头函数
let arrow = func(x: int, y: int): int => x + y

// print/println 测试
let name = "Alice"
let age = 25
let x = 100

// 基本 print/println
print("Hello ")
println("World")

// 带模板字符串的 print/println
println("Hello, ${name}!")
print("Age: ${age}, ")
println("Name: ${name}")

// 多个参数包含模板字符串
println("Coords: ${x}", "Value: ${age}")

// 普通参数和模板字符串混合
println("User:", name, "is ${age} years old")
