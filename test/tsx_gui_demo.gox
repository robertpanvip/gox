package main

import "github.com/gox-lang/gox/gui"

func Main() {
    let app = gui.NewApp("Gox TSX Demo", 800, 600)
    
    let titleLabel = <Label text="Welcome to Gox GUI!" size={24} color={gui.ColorBlue} />
    app.Root.AddChild(titleLabel)
    
    let descLabel = <Label text="TSX syntax is working!" size={18} />
    app.Root.AddChild(descLabel)
    
    let counterLabel = <Label text="Counter: 0" size={16} />
    app.Root.AddChild(counterLabel)
    
    let clickButton = <Button text="Click Me!" />
    clickButton.OnClick = func() {
        println("Button clicked!")
    }
    app.Root.AddChild(clickButton)
    
    let closeButton = <Button text="Close" />
    app.Root.AddChild(closeButton)
    
    app.Run()
}
