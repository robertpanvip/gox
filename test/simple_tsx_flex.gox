package main

import "github.com/gox-lang/gox/gui"

func Main() {
	let app = gui.NewApp("Simple TSX Flex", 800, 600)
	
	// 简单的垂直布局
	let container = <Div
		style={gui.DefaultStyle().
			SetFlexDirection(gui.FlexColumn).
			SetPaddingAll(20).
			SetBorderWidth(2).
			SetBorderColor(gui.ColorRed)}
	>
		<Label text="Title" size={24} color={gui.ColorBlue} />
		<Button text="Click" size={16} color={gui.ColorWhite} />
	</Div>
	
	container.SetRect({X: 0, Y: 0, Width: 800, Height: 600})
	app.Root.AddChild(container)
	app.Run()
}
