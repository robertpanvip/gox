package main

import go "fmt"

public func Main() {
    fmt.println("gg library demo")
    fmt.println("Install: go get github.com/fogleman/gg")
    fmt.println("")
    fmt.println("Example code:")
    fmt.println(`
package main

import (
    "github.com/fogleman/gg"
)

func main() {
    // Create 800x600 canvas
    dc := gg.NewContext(800, 600)
    
    // Set background color (light gray)
    dc.SetRGB(0.9, 0.9, 0.9)
    dc.Clear()
    
    // Draw red rectangle
    dc.SetRGB(1, 0, 0)
    dc.DrawRectangle(100, 100, 200, 150)
    dc.Fill()
    
    // Draw blue circle
    dc.SetRGB(0, 0, 1)
    dc.DrawCircle(400, 300, 80)
    dc.SetLineWidth(5)
    dc.Stroke()
    
    // Draw green ellipse
    dc.SetRGB(0, 1, 0)
    dc.DrawEllipse(600, 400, 100, 50)
    dc.Fill()
    
    // Draw text
    dc.SetRGB(0, 0, 0)
    dc.LoadFontFace("Arial", 24)
    dc.DrawString("Hello from Gox + gg!", 50, 50)
    
    // Save to PNG file
    dc.SavePNG("output.png")
}
    `)
}
