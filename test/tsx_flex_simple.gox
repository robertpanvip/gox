package main

import "github.com/gox-lang/gox/gui"

func Main() {
	let app = gui.NewApp("TSX Flex Test", 900, 600)
	
	// 使用 TSX 语法 - CSS style 对象字面量
	let rootDiv = <Div style={{display: "flex", flexDirection: "column", padding: "10px", backgroundColor: "#f0f0f0", borderWidth: "3px", borderColor: "red"}}>
		// Header
		<Div style={{display: "flex", flexDirection: "row", justifyContent: "center", padding: "15px", backgroundColor: "#ffffc8", borderWidth: "2px", borderColor: "blue"}}>
			<Label text="HEADER" fontSize={18} textColor={gui.ColorBlue} />
		</Div>
		
		// 内容区域（middle）
		<Div style={{display: "flex", flexDirection: "row", justifyContent: "space-around", padding: "10px", flexGrow: 1, backgroundColor: "#dcffe0", borderWidth: "2px", borderColor: "green"}}>
			<Div style={{padding: "10px", flexGrow: 1, backgroundColor: "#ffdcef", borderWidth: "2px", borderColor: "purple"}}>
				<Label text="LEFT" fontSize={14} textColor={gui.ColorPurple} />
			</Div>
			
			<Div style={{padding: "10px", flexGrow: 2, backgroundColor: "#ffebc8", borderWidth: "2px", borderColor: "orange"}}>
				<Label text="CENTER" fontSize={14} textColor={gui.ColorOrange} />
			</Div>
			
			<Div style={{padding: "10px", flexGrow: 1, backgroundColor: "#c8ffff", borderWidth: "2px", borderColor: "cyan"}}>
				<Label text="RIGHT" fontSize={14} textColor={gui.ColorCyan} />
			</Div>
		</Div>
		
		// Footer
		<Div style={{display: "flex", flexDirection: "row", justifyContent: "center", padding: "15px", backgroundColor: "#ffffdc", borderWidth: "2px", borderColor: "orange"}}>
			<Label text="FOOTER" fontSize={16} textColor={gui.ColorOrange} />
		</Div>
	</Div>
	
	app.Root.AddChild(rootDiv)
	
	println("Starting TSX Flex Test...")
	app.Run()
}
