package main

import go "fmt"
import go "github.com/hajimehoshi/ebiten/v2"
import go "github.com/fogleman/gg"

// 简单的 Ebiten 示例
public func Main() {
    fmt.println("=== Gox + gg + Ebiten Simple Demo ===")
    
    // 1. 使用 gg 绘图
    let dc = gg.NewContext(800, 600)
    
    // 背景
    dc.SetRGB(1, 1, 1)
    dc.Clear()
    
    // 红色圆形
    dc.SetRGB(1, 0, 0)
    dc.DrawCircle(400, 300, 100)
    dc.Fill()
    
    // 绿色矩形
    dc.SetRGB(0, 1, 0)
    dc.DrawRectangle(200, 200, 150, 150)
    dc.Fill()
    
    // 蓝色椭圆
    dc.SetRGB(0, 0, 1)
    dc.DrawEllipse(600, 400, 120, 60)
    dc.Fill()
    
    // 文字
    dc.SetRGB(0, 0, 0)
    dc.DrawString("Hello from Gox!", 50, 50)
    dc.DrawString("gg + Ebiten", 50, 80)
    
    // 2. 保存为图片
    dc.SavePNG("ebiten_demo.png")
    
    fmt.println("Image created: ebiten_demo.png")
    fmt.println("")
    fmt.println("To run with Ebiten, use this Go code:")
    fmt.println("")
    fmt.Println("package main")
    fmt.Println("")
    fmt.Println("import (")
    fmt.Println(`    "image/color"`)
    fmt.Println(`    "github.com/hajimehoshi/ebiten/v2"`)
    fmt.Println(`    "github.com/fogleman/gg"`)
    fmt.Println(")")
    fmt.Println("")
    fmt.Println("type Game struct {")
    fmt.Println("    img *ebiten.Image")
    fmt.Println("}")
    fmt.Println("")
    fmt.Println("func (g *Game) Update() error { return nil }")
    fmt.Println("")
    fmt.Println("func (g *Game) Draw(screen *ebiten.Image) {")
    fmt.Println("    screen.DrawImage(g.img, nil)")
    fmt.Println("}")
    fmt.Println("")
    fmt.Println("func (g *Game) Layout(w, h int) (int, int) {")
    fmt.Println("    return 800, 600")
    fmt.Println("}")
    fmt.Println("")
    fmt.Println("func main() {")
    fmt.Println("    dc := gg.NewContext(800, 600)")
    fmt.Println("    dc.SetRGB(1, 1, 1)")
    fmt.Println("    dc.Clear()")
    fmt.Println("    dc.SetRGB(1, 0, 0)")
    fmt.Println("    dc.DrawCircle(400, 300, 100)")
    fmt.Println("    dc.Fill()")
    fmt.Println("    ")
    fmt.Println("    img := dc.Image()")
    fmt.Println("    ebitenImg := ebiten.NewImageFromImage(img)")
    fmt.Println("    ")
    fmt.Println("    ebiten.SetWindowSize(800, 600)")
    fmt.Println("    ebiten.SetWindowTitle(\"Gox + gg + Ebiten\")")
    fmt.Println("    ebiten.RunGame(&Game{img: ebitenImg})")
    fmt.Println("}")
    fmt.Println("")
    fmt.Println("Save as 'ebiten_demo.go' and run:")
    fmt.Println("  go run ebiten_demo.go")
}
