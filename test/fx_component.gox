import "github.com/gox-lang/gox/gui"

fx func Counter() {
    let count = 0
    
    return <button text="Click Me" onClick={() => {
        count++
        println("Count updated:", count)
    }} />
}

func Main() {
    // 创建应用窗口
    let app = gui.NewApp("FX Component Demo", 800, 600)
    
    // 创建 Counter 组件
    let counter = NewCounter()
    
    // 将组件添加到窗口
    let div = gui.NewDiv(gui.DivProps{})
    div.AddChild(counter)
    
    app.SetRootComponent(div)
    
    // 运行应用
    app.Run()
}