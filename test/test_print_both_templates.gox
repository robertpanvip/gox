package main

let name = "Alice"
let age = 25
let x = 100
let y = 200

// 双引号模板字符串（现在支持）
println("Hello, ${name}!")
print("Age: ${age}")
println("X: ${x}, Y: ${y}")

// 反引号模板字符串（也支持）
println(`Name: ${name}`)
print(`Age: ${age}`)

// 混合使用
println("User:", name, `is ${age} years old`)
println("Coords: ${x}", "Value: ${y}")

// 普通字符串（无模板）
println("Hello World")
print("No template here")
