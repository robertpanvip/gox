package main

import go "fmt"

// 测试泛型函数
public func identity[T](x: T): T {
    return x
}

public func printValue[T](x: T) {
    fmt.Println(x)
}

public func swap[T](a: T, b: T): (T, T) {
    return b, a
}

// 测试泛型结构体
public struct Container[T] {
    public value: T
}

public func (c: Container[T]) GetValue(): T {
    return c.value
}

public func (c: Container[T]) SetValue(value: T) {
    c.value = value
}

public func Main() {
    // 测试泛型函数
    let num = identity[int](42)
    let str = identity[string]("hello")
    
    fmt.println(num)
    fmt.println(str)
    
    // 测试泛型结构体
    let container = Container[int]{value: 100}
    fmt.println(container.GetValue())
    
    let strContainer = Container[string]{value: "world"}
    fmt.println(strContainer.GetValue())
}
