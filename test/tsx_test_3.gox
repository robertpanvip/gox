package main

import "github.com/gox-lang/gox/gui"

func Main() {
	// 测试用例 3: TSX 多组件布局
	let app = gui.NewApp("TSX Test 3: Multiple Components", 800, 600)
	
	// 标题
	let title = <Label text="Component Layout Test" size={24} color={gui.ColorBlue} />
	title.SetRect({X: 50, Y: 30, Width: 400, Height: 30})
	app.Root.AddChild(title)
	
	// 红色按钮
	let btnRed = <Button text="Red Button" size={16} color={gui.ColorWhite} backcolor={gui.ColorRed} />
	btnRed.SetRect({X: 50, Y: 80, Width: 120, Height: 40})
	btnRed.OnClick = func() { println("Red button clicked!") }
	app.Root.AddChild(btnRed)
	
	// 绿色按钮
	let btnGreen = <Button text="Green Button" size={16} color={gui.ColorWhite} backcolor={gui.ColorGreen} />
	btnGreen.SetRect({X: 180, Y: 80, Width: 120, Height: 40})
	btnGreen.OnClick = func() { println("Green button clicked!") }
	app.Root.AddChild(btnGreen)
	
	// 蓝色按钮
	let btnBlue = <Button text="Blue Button" size={16} color={gui.ColorWhite} backcolor={gui.ColorBlue} />
	btnBlue.SetRect({X: 310, Y: 80, Width: 120, Height: 40})
	btnBlue.OnClick = func() { println("Blue button clicked!") }
	app.Root.AddChild(btnBlue)
	
	// 状态标签
	let statusLabel = <Label text="Status: Waiting..." size={16} color={gui.ColorBlack} />
	statusLabel.SetRect({X: 50, Y: 150, Width: 300, Height: 30})
	app.Root.AddChild(statusLabel)
	
	// 更新状态按钮
	let btnStatus = <Button text="Update Status" size={16} color={gui.ColorBlack} backcolor={gui.ColorLightGray} />
	btnStatus.SetRect({X: 50, Y: 200, Width: 150, Height: 40})
	btnStatus.OnClick = func() {
		statusLabel.SetText("Status: Updated!")
		println("Status updated!")
	}
	app.Root.AddChild(btnStatus)
	
	println("Running TSX Test 3...")
	app.Run()
}
