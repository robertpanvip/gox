package main

import "github.com/gox-lang/gox/gui"

func Main() {
	// 测试用例 2: TSX 按钮交互
	let app = gui.NewApp("TSX Test 2: Button Interaction", 800, 600)
	
	let title = <Label text="Button Click Test" size={24} color={gui.ColorBlue} />
	title.SetRect({X: 50, Y: 50, Width: 300, Height: 30})
	app.Root.AddChild(title)
	
	let counter = 0
	let counterLabel = <Label text="Clicks: 0" size={18} color={gui.ColorGreen} />
	counterLabel.SetRect({X: 50, Y: 100, Width: 200, Height: 30})
	app.Root.AddChild(counterLabel)
	
	let button = <Button text="Click Me!" size={16} color={gui.ColorBlack} backcolor={gui.ColorLightGray} />
	button.SetRect({X: 50, Y: 150, Width: 150, Height: 40})
	button.OnClick = func() {
		counter++
		counterLabel.SetText(fmt.Sprintf("Clicks: %d", counter))
		println("Button clicked", counter, "times")
	}
	app.Root.AddChild(button)
	
	println("Running TSX Test 2...")
	app.Run()
}
