package main

import go "fmt"

public struct Person {
    public Name: string
    private age: int
}

public func NewPerson(name: string, age: int): Person {
    return Person{Name: name, age: age}
}

public func (p: Person) GetName(): string {
    return p.Name
}

private func (p: Person) getAge(): int {
    return p.age
}

public func Main() {
    let p = NewPerson("Alice", 25)
    fmt.println(p.GetName())
}
