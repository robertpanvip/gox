package main

import go "fmt"
import go "github.com/fogleman/gg"

public func Main() {
    fmt.println("Gox plus gg Demo")
    
    let dc = gg.NewContext(800, 600)
    dc.SetRGB(1, 1, 1)
    dc.Clear()
    
    dc.SetRGB(1, 0, 0)
    dc.DrawCircle(400, 300, 100)
    dc.Fill()
    
    dc.SetRGB(0, 1, 0)
    dc.DrawRectangle(200, 200, 150, 150)
    dc.Fill()
    
    dc.SetRGB(0, 0, 1)
    dc.DrawEllipse(600, 400, 120, 60)
    dc.Fill()
    
    dc.SetRGB(0, 0, 0)
    dc.DrawString("Hello from Gox", 50, 50)
    
    dc.SavePNG("demo.png")
    
    fmt.println("Image created: demo.png")
    fmt.println("Open it with: start demo.png")
}
