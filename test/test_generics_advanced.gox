package main

import go "fmt"

// 测试多类型参数
public func swap[T, U](a: T, b: U): (T, U) {
    return b, a
}

// 测试泛型数组
public func first[T](arr: T[]): T {
    return arr[0]
}

public func Main() {
    // 测试多类型参数
    let (x, y) = swap[int, string](42, "hello")
    fmt.Println(x)
    fmt.Println(y)
    
    // 测试泛型数组
    let numbers = [1, 2, 3, 4, 5]
    let firstNum = first[int](numbers)
    fmt.Println(firstNum)
    
    let strings = ["a", "b", "c"]
    let firstStr = first[string](strings)
    fmt.Println(firstStr)
}
