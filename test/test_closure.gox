package main

import go "fmt"

// 测试闭包：返回函数
public func makeAdder(x: int): (int) => int {
    return (n: int) => x + n
}

// 测试闭包：计数器
public func makeCounter(): () => int {
    let count = 0
    return () => {
        count = count + 1
        return count
    }
}

// 测试闭包：高阶函数
public func mapArray(arr: int[], fn: (int) => int): int[] {
    let result: int[] = []
    for i < len(arr) {
        result[i] = fn(arr[i])
    }
    return result
}

public func Main() {
    // 测试返回函数的闭包
    let add5 = makeAdder(5)
    let add10 = makeAdder(10)
    
    fmt.Println(add5(3))  // 8
    fmt.Println(add10(3)) // 13
    
    // 测试计数器闭包
    let counter = makeCounter()
    fmt.Println(counter()) // 1
    fmt.Println(counter()) // 2
    fmt.Println(counter()) // 3
    
    // 测试高阶函数
    let numbers = [1, 2, 3, 4, 5]
    let doubled = mapArray(numbers, (n: int) => n * 2)
    fmt.Println(doubled) // [2, 4, 6, 8, 10]
}
