package main

import "github.com/gox-lang/gox/gui"

func Main() {
    app := gui.NewApp("TSX Demo", 800, 600)
    
    let titleLabel = <Label text="Welcome to Gox GUI!" size={24} />
    app.Root.AddChild(titleLabel)
    
    let button = <Button text="Click Me" />
    button.OnClick = func() {
        println("Button clicked!")
    }
    app.Root.AddChild(button)
    
    app.Run()
}
