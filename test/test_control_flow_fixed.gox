package main

import go "fmt"

public func Main() {
    // μΚ‘ξ»Ύ if ξ»ΙλΉΒ
    let x = 10
    if x > 5 {
        fmt.Println("x is greater than 5")
    } else {
        fmt.Println("x is not greater than 5")
    }
    
    // μΚ‘ξ»Ύ while λΟΗν―»
    let i = 0
    while i < 5 {
        fmt.Println(`i is ${i}`)
        i = i + 1
    }
    
    // μΚ‘ξ»Ύ for λΟΗν―»
    for i < 10 {
        if i == 7 {
            break
        }
        fmt.Println(`i is ${i}`)
        i = i + 1
    }
    
    // μΚ‘ξ»Ύ switch ξ»ΙλΉΒ
    let day = 3
    switch day {
    case 1: {
        fmt.Println("Monday")
    }
    case 2: {
        fmt.Println("Tuesday")
    }
    case 3: {
        fmt.Println("Wednesday")
    }
    default: {
        fmt.Println("Other day")
    }
    }
}
