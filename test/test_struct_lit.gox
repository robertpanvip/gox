package main

// 定义结构体
public struct User {
    public name: string
    public age: int
    public email: string
}

public struct Point {
    public x: int
    public y: int
}

public struct Rect {
    public x: int
    public y: int
    public width: int
    public height: int
}

// 带字段名的初始化（推荐）
let user1 = User{
    name: "Alice",
    age: 25,
    email: "alice@example.com"
}

// 位置初始化（按字段顺序）
let point1 = Point{10, 20}

// 混合使用
let rect1 = Rect{
    x: 0,
    y: 0,
    width: 100,
    height: 200
}

// 使用表达式
let x = 10
let y = 20
let point2 = Point{x: x, y: y}
let point3 = Point{x + 5, y + 10}

// 嵌套结构体
public struct Container {
    public user: User
    public point: Point
}

let container = Container{
    user: User{name: "Bob", age: 30, email: "bob@example.com"},
    point: Point{100, 200}
}

// 打印测试
println(`User: ${user1.name}, Age: ${user1.age}`)
println(`Point: (${point1.x}, ${point1.y})`)
println(`Rect: (${rect1.x}, ${rect1.y}, ${rect1.width}, ${rect1.height})`)
