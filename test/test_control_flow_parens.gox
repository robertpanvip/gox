package main

// 带括号的 if 语句
public func Main() {
    let x = 15
    if (x > 10) {
        println("big")
    } else if (x > 5) {
        println("medium")
    } else {
        println("small")
    }
    
    // 带括号的 while 循环
    let i = 0
    while (i < 5) {
        println(`i is ${i}`)
        i = i + 1
    }
    
    // 带括号的 for 循环
    for (i < 10) {
        if (i == 7) {
            break
        }
        if (i % 2 == 0) {
            i = i + 1
            continue
        }
        println(`i is ${i}`)
        i = i + 1
    }
    
    // 带括号的 switch 语句
    let day = 3
    switch (day) {
    case 1: {
        println("Monday")
    }
    case 2: {
        println("Tuesday")
    }
    case 3: {
        println("Wednesday")
    }
    }
    
    // 带括号的 when 语句
    let grade = "A"
    when (grade) {
    case "A": {
        println("Excellent")
    }
    case "B": {
        println("Good")
    }
    }
    
    // 不带括号的 if 语句
    if x > 10 {
        println("big")
    }
    
    // 不带括号的 while 循环
    while i < 5 {
        i = i + 1
    }
    
    // 不带括号的 for 循环
    for i < 10 {
        i = i + 1
    }
    
    // 不带括号的 switch 语句
    switch x {
    case 1: {
        println("one")
    }
    }
    
    // 不带括号的 when 语句
    let y = 2
    when y {
    case 2: {
        println("two")
    }
    }
}
