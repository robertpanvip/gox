package main

let name = "Alice"
let age = 25
let x = 100
let y = 200

// 基本 print/println
print("Hello ")
println("World")

// 带模板字符串的 print/println
println("Hello, ${name}!")
print("Age: ${age}, ")
println("Name: ${name}")

// 多个参数包含模板字符串
println("Coords: ${x}", "Value: ${y}")

// 普通参数和模板字符串混合
println("User:", name, "is ${age} years old")
